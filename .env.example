# Copy to .env and fill in. NEVER commit the real .env.
TNP_IDENTITY=TPBIT-BTECH1024223
TNP_PASSWORD=your-password-here
TNP_CENTRE=
POLL_INTERVAL_MIN=15
LOG_LEVEL=INFO

# --- Notifications ---
# Active channels, comma-separated: console | ntfy | discord
NOTIFY_CHANNELS=ntfy

# ntfy.sh (no account). Use a long, hard-to-guess topic and share it with friends,
# who subscribe in the ntfy app (https://ntfy.sh app / F-Droid / App Store).
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=tnp-bit-CHANGE-ME-to-something-random
NTFY_TOKEN=

# Discord webhook (Channel Settings -> Integrations -> Webhooks -> New Webhook)
DISCORD_WEBHOOK_URL=
